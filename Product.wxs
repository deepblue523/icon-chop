<?xml version="1.0" encoding="utf-8"?>
<Wix xmlns="http://wixtoolset.org/schemas/v4/wxs">
  <Package Id="IconChop" Name="IconChop" Manufacturer="IconChop" Version="$(var.ProductVersion)"
           UpgradeCode="a1b2c3d4-e5f6-4a5b-8c9d-0e1f2a3b4c5d">
    <MajorUpgrade DowngradeErrorMessage="A newer version of IconChop is already installed." />
    <MediaTemplate EmbedCab="yes" />
    <Feature Id="MainFeature" Title="IconChop" Level="1">
      <ComponentGroupRef Id="HarvestedApp" />
    </Feature>
    <StandardDirectory Id="ProgramFiles64Folder">
      <Directory Id="INSTALLFOLDER" Name="IconChop" />
    </StandardDirectory>
  </Package>
</Wix>
